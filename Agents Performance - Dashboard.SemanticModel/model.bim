                "value": "TimeIntelligence"
              },
              {
                "name": "SQLBI_TimeIntelligence",
                "value": "Standard"
              },
              {
                "name": "SQLBI_CalendarType",
                "value": "Calendar"
              }
            ],
            "displayFolder": "Time intelligence\\To-date total\\Total Sales",
            "expression": [
              "",
              "IF (",
              "    [_ShowValueForDates],",
              "    CALCULATE (",
              "        [Total Sales],",
              "        DATESMTD ( 'Date'[Date] )",
              "    )",
              ")"
            ],
            "lineageTag": "17d3a026-0ce0-416f-939c-84333c5bcc2d"
          },
          {
            "name": "PY Total Sales",
            "annotations": [
              {
                "name": "SQLBI_Template",
                "value": "TimeIntelligence"
              },
              {
                "name": "SQLBI_TimeIntelligence",
                "value": "Standard"
              },
              {
                "name": "SQLBI_CalendarType",
                "value": "Calendar"
              }
            ],
            "displayFolder": "Time intelligence\\Growth\\Total Sales",
            "expression": [
              "",
              "IF (",
              "    [_ShowValueForDates],",
              "    CALCULATE (",
              "        [Total Sales],",
              "        CALCULATETABLE (",
              "            DATEADD ( 'Date'[Date], -1, YEAR ),",
              "            'Date'[DateWithTransactions] = TRUE",
              "        )",
              "    )",
              ")"
            ],
            "lineageTag": "8f4ce316-2cd7-44fa-93a1-e9b18319b76c"
          },
          {
            "name": "YOY Total Sales",
            "annotations": [
              {
                "name": "SQLBI_Template",
                "value": "TimeIntelligence"
              },
              {
                "name": "SQLBI_TimeIntelligence",
                "value": "Standard"
              },
              {
                "name": "SQLBI_CalendarType",
                "value": "Calendar"
              }
            ],
            "displayFolder": "Time intelligence\\Growth\\Total Sales",
            "expression": [
              "",
              "VAR __ValueCurrentPeriod = [Total Sales]",
              "VAR __ValuePreviousPeriod = [PY Total Sales]",
              "VAR __Result =",
              "    IF (",
              "        NOT ISBLANK ( __ValueCurrentPeriod ) && NOT ISBLANK ( __ValuePreviousPeriod ),",
              "        __ValueCurrentPeriod - __ValuePreviousPeriod",
              "    )",
              "RETURN",
              "    __Result"
            ],
            "lineageTag": "797f2833-2b0b-4e63-bb68-65357a92d3ee"
          },
          {
            "name": "YOY % Total Sales",
            "annotations": [
              {
                "name": "SQLBI_Template",
                "value": "TimeIntelligence"
              },
              {
                "name": "SQLBI_TimeIntelligence",
