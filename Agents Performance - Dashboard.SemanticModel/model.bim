              "VAR _Result =",
              "SWITCH( ",
              "    TRUE(),",
              "    SELECTEDVALUE( DimEmployee[EmployeeKey] ) IN _Rank_Asc, 1,",
              "    SELECTEDVALUE( DimEmployee[EmployeeKey] ) IN _Rank_Desc, 1,",
              "    _Rank_Middle_Empty_Bar IN { _Selected_Top_Bottom_N + 1, _Selected_Top_Bottom_N + 2}, 1,",
