          {
            "name": "Employee Name",
            "displayFolder": "Table Dyamics",
            "expression": [
              "",
              "",
              "VAR _Selected_Top_Bottom_N = 'Top-Bottom-N'[Top-Bottom-N Value]",
              "",
              "VAR _Rank_Middle_Empty_Bar =",
              "RANKX( FILTER( ALL( DimEmployee[EmployeeKey] ),NOT ISBLANK( [MTD Total Sales] )) , [MOMTD % Total Sales], , DESC ) ",
              "",
              "VAR _Rank_Middle_Empty_Bar_MTD =",
              "RANKX( FILTER( ALL( DimEmployee[EmployeeKey] ),NOT ISBLANK( [MTD Total Sales] )) , [MTD Total Sales], , DESC ) ",
              "",
              "VAR _Result_1 =",
              "IF( ",
              "    _Rank_Middle_Empty_Bar IN { _Selected_Top_Bottom_N + 1, _Selected_Top_Bottom_N + 2}, \"⋮\",",
              "    SELECTEDVALUE( DimEmployee[FirstName] ) & \" \" & SELECTEDVALUE( DimEmployee[LastName]) ",
              ")",
              "",
              "VAR _Result_2 =",
              "IF( ",
              "    _Rank_Middle_Empty_Bar_MTD IN { _Selected_Top_Bottom_N + 1, _Selected_Top_Bottom_N + 2}, \"⋮\",",
              "    SELECTEDVALUE( DimEmployee[FirstName] ) & \" \" & SELECTEDVALUE( DimEmployee[LastName]) ",
              ")",
              "",
              "VAR _Result = ",
              "IF( ",
              "    SELECTEDVALUE( 'Actuals-vs-PctChange'[Top-Bottom-Field] ) = \"MTD Sales\", ",
              "    _Result_2, _Result_1 )",
              "",
              "RETURN _Result ",
              ""
            ],
            "lineageTag": "4fb3effd-53d4-462d-9f48-8a7f11d76a54"
          },
          {
            "name": "vs Previous Month",
            "displayFolder": "Table Dyamics",
            "expression": [
              "",
              "",
              "VAR _Selected_Top_Bottom_N = 'Top-Bottom-N'[Top-Bottom-N Value]",
              "",
              "VAR _Rank_Middle_Empty_Bar =",
              "RANKX( FILTER( ALL( DimEmployee[EmployeeKey] ),NOT ISBLANK( [MTD Total Sales] )) , [MOMTD % Total Sales], , DESC ) ",
              "",
              "VAR _Rank_Middle_Empty_Bar_MTD =",
              "RANKX( FILTER( ALL( DimEmployee[EmployeeKey] ),NOT ISBLANK( [MTD Total Sales] )) , [MTD Total Sales], , DESC ) ",
              "",
              "VAR _Result_1 =",
              "IF( ",
              "    _Rank_Middle_Empty_Bar IN { _Selected_Top_Bottom_N + 1, _Selected_Top_Bottom_N + 2}, BLANK(),",
              "    [MOMTD % Total Sales]",
              ")",
              "",
              "VAR _Result_2 =",
              "IF( ",
              "    _Rank_Middle_Empty_Bar_MTD IN { _Selected_Top_Bottom_N + 1, _Selected_Top_Bottom_N + 2}, BLANK(),",
              "    [MTD Total Sales]",
              ")",
              "",
              "VAR _Result =",
              "IF( ",
              "    SELECTEDVALUE( 'Actuals-vs-PctChange'[Top-Bottom-Field]) = \"MTD Sales\",",
              "    _Result_2, _Result_1",
              ")",
              "",
              "",
              "RETURN _Result "
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "13abb6d4-b70d-4fd5-8c28-fbfa9cf3bbc7"
          },
          {
            "name": "vs PM MOM%",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ],
            "displayFolder": "Table Dyamics",
            "expression": [
              "",
              "",
              "VAR _Selected_Top_Bottom_N = 'Top-Bottom-N'[Top-Bottom-N Value]",
              "",
              "VAR _Rank_Middle_Empty_Bar =",
              "RANKX( FILTER( ALL( DimEmployee[EmployeeKey] ),NOT ISBLANK( [MTD Total Sales] )) , [MOMTD % Total Sales], , DESC )",
              "",
              "VAR _Rank_Middle_Empty_Bar_MTD =",
              "RANKX( FILTER( ALL( DimEmployee[EmployeeKey] ),NOT ISBLANK( [MTD Total Sales] )) , [MTD Total Sales], , DESC )  ",
              "",
              "VAR _Result_1 =",
              "IF( ",
              "    _Rank_Middle_Empty_Bar IN { _Selected_Top_Bottom_N + 1, _Selected_Top_Bottom_N + 2}, \"⋮\",",
              "    [MOMTD % Total Sales] ",
              ")",
              "",
              "VAR _Result_2 =",
              "IF( ",
              "    _Rank_Middle_Empty_Bar_MTD IN { _Selected_Top_Bottom_N + 1, _Selected_Top_Bottom_N + 2}, \"⋮\",",
              "    [MOMTD % Total Sales] ",
              ")",
              "",
              "VAR _Result = ",
              "IF(",
              "    SELECTEDVALUE( 'Actuals-vs-PctChange'[Top-Bottom-Field] ) =\"MTD Sales\", _Result_2, _Result_1 )",
              "",
              "",
              "RETURN _Result ",
              ""
            ],
            "formatString": "▲ 0.0%; ▼ -0.0%",
            "lineageTag": "8b364965-b9ff-4062-921f-128f31f98c7f"
          },
          {
            "name": "CF Table",
            "displayFolder": "Table Dyamics",
            "expression": [
              "",
              "VAR _Selected_Top_Bottom_N = 'Top-Bottom-N'[Top-Bottom-N Value]",
              "",
              "VAR _Rank_Middle_Empty_Bar =",
              "RANKX( FILTER( ALL( DimEmployee[EmployeeKey] ),NOT ISBLANK( [MTD Total Sales] )) , [MOMTD % Total Sales], , DESC ) ",
              "",
              "VAR _Rank_Middle_Empty_Bar_MTD =",
              "RANKX( FILTER( ALL( DimEmployee[EmployeeKey] ),NOT ISBLANK( [MTD Total Sales] )) , [MTD Total Sales], , DESC )",
              "",
              "VAR _Result_1 =",
              "IF( ",
              "    _Rank_Middle_Empty_Bar IN { _Selected_Top_Bottom_N + 1, _Selected_Top_Bottom_N + 2}, \"white\",",
              "    \"black\"",
              ")",
              "",
              "VAR _Result_2 =",
              "IF( ",
              "    _Rank_Middle_Empty_Bar_MTD IN { _Selected_Top_Bottom_N + 1, _Selected_Top_Bottom_N + 2}, \"white\",",
              "    \"black\"",
              ")",
              " ",
              "",
              "VAR _Result = ",
              "IF( ",
              "    SELECTEDVALUE( 'Actuals-vs-PctChange'[Top-Bottom-Field] ) = \"MTD Sales\", ",
              "    _Result_2, _Result_1 )",
              "",
              "",
              "RETURN _Result "
            ],
            "lineageTag": "2626d349-bdbd-4715-9c4c-73ca522c7388"
          },
          {
            "name": "Number of Employees with Positive Change",
            "displayFolder": "-KPI- Positive Change",
            "expression": [
              "",
              "COUNTX( ",
              "    FILTER( ALL( DimEmployee[EmployeeKey] ), [MOMTD Total Sales] > 0 ),",
              "    DimEmployee[EmployeeKey] )"
            ],
            "formatString": "0",
            "lineageTag": "436bd3a1-7b6f-41d5-a9fb-161a5811dec8"
          },
          {
            "name": "Employees with Positive Change %",
            "displayFolder": "-KPI- Positive Change",
            "expression": [
              "",
              "VAR _Total_Employees = CALCULATE( COUNT( DimEmployee[EmployeeKey] ), ALL( DimEmployee ) )",
              "",
              "VAR _Result = DIVIDE([Number of Employees with Positive Change] , _Total_Employees )",
              "",
              "RETURN _Result "
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "d3c01ce8-bd22-4987-9a2e-e1224fc28ccd"
          },
          {
            "name": "Employees Avg MTD % Change",
            "displayFolder": "-KPI-Avg MTD % Change",
            "expression": [
              "",
              "",
              "AVERAGEX( ALL( DimEmployee[EmployeeKey] ), [MOMTD % Total Sales] )"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "611f0cc7-eafd-41a9-9725-162c1f828590"
          },
          {
            "name": "Employees Avg MTD Sales",
            "displayFolder": "-KPI- Avg MTD Sales",
            "expression": [
              "",
              "AVERAGEX( ALLSELECTED( DimEmployee[EmployeeKey] ), [MTD Total Sales] )"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "lineageTag": "3f3818d7-7ce5-443f-8498-0d4a848c4b24"
          },
          {
            "name": "Number of Employees selling more than 100K MTD",
            "displayFolder": "-KPI-Number of Employees Sold more than 100K",
            "expression": [
              "",
              "COUNTX( FILTER( ALL( DimEmployee[EmployeeKey] ), [MTD Total Sales] >= 100000 ), DimEmployee[EmployeeKey] )"
            ],
            "formatString": "0",
            "lineageTag": "92d414c4-e34b-4136-b744-6e920d4f6c23"
          },
          {
            "name": "Table MTD Sales",
            "displayFolder": "Table Dyamics",
            "expression": [
              "",
              "",
              "VAR _Selected_Top_Bottom_N = 'Top-Bottom-N'[Top-Bottom-N Value]",
              "",
              "VAR _Rank_Middle_Empty_Bar =",
              "RANKX( FILTER( ALL( DimEmployee[EmployeeKey] ),NOT ISBLANK( [MTD Total Sales] )) , [MOMTD % Total Sales], , DESC ) ",
              "",
              "VAR _Rank_Middle_Empty_Bar_MTD =",
              "RANKX( FILTER( ALL( DimEmployee[EmployeeKey] ),NOT ISBLANK( [MTD Total Sales] )) , [MTD Total Sales], , DESC ) ",
              "",
              "VAR _Result_1 =",
              "IF( ",
              "    _Rank_Middle_Empty_Bar IN { _Selected_Top_Bottom_N + 1, _Selected_Top_Bottom_N + 2}, \"⋮\",",
              "    FORMAT( [MTD Total Sales], \"$#,##0\") ",
              ")",
              "",
              "VAR _Result_2 = ",
              "IF( ",
              "    _Rank_Middle_Empty_Bar_MTD IN { _Selected_Top_Bottom_N + 1, _Selected_Top_Bottom_N + 2}, \"⋮\",",
              "    FORMAT( [MTD Total Sales], \"$#,##0\") ",
              ")",
              "",
              "VAR _Result =",
              "IF( ",
              "    SELECTEDVALUE( 'Actuals-vs-PctChange'[Top-Bottom-Field]) = \"MTD Sales\",",
              "    _Result_2, _Result_1",
              ")",
              "",
              "",
              "",
              "RETURN _Result ",
              ""
            ],
            "lineageTag": "a6a4a6a2-59dc-4d1b-844d-d8e022b86118"
          },
          {
            "name": "Return Quantity",
            "expression": "SUM( FactSales[ReturnQuantity] )",
            "formatString": "0",
            "lineageTag": "40ab80e2-29b7-4fd6-9cbb-e72ff91379c6"
          },
          {
            "name": "Profit",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "SUMX( FactSales, FactSales[SalesAmount] - FactSales[TotalCost] )",
            "lineageTag": "b1e8d60a-dcf1-4822-9c74-05dca6682411"
          },
          {
            "name": "Profit Margin",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "DIVIDE( [Profit] , [Total Sales] )",
            "lineageTag": "b3183ca7-1b0f-484c-be72-b19ede867a16"
          },
          {
            "name": "Total Discount",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "SUM( FactSales[DiscountAmount] )",
            "lineageTag": "c10b61e9-4f6b-47c8-96db-14fbaba4a8db"
          },
          {
            "name": "Quantity Sold",
            "expression": "SUM( FactSales[SalesQuantity] )",
            "formatString": "0",
            "lineageTag": "35088c52-7ac7-4fef-8f7b-fc91996e33ba"
          },
          {
            "name": "Rank Filtering Employyees MTD% CF",
            "displayFolder": "Table Dyamics",
            "expression": [
              "",
              "",
              "VAR _Selected_Top_Bottom_N = 'Top-Bottom-N'[Top-Bottom-N Value]",
              "",
              "VAR _Rank_Asc =",
              "TOPN( ",
              "    _Selected_Top_Bottom_N ,",
              "    FILTER( ALL( DimEmployee[EmployeeKey] ),",
              "            NOT ISBLANK( [MTD Total Sales] ) ",
              "        ),",
              "    [MOMTD % Total Sales], ASC )",
              "",
              "VAR _Rank_Desc =",
              "TOPN( ",
              "    _Selected_Top_Bottom_N ,",
              "    FILTER( ALL( DimEmployee[EmployeeKey] ),",
              "            NOT ISBLANK( [MTD Total Sales] ) ",
              "        ),",
              "    [MOMTD % Total Sales], DESC )",
              "",
              "VAR _Rank_Middle_Empty_Bar =",
              "RANKX( FILTER( ALL( DimEmployee[EmployeeKey] ),NOT ISBLANK( [MTD Total Sales] )) , [MOMTD % Total Sales], , DESC ) ",
              "",
              "VAR _Result =",
              "IF(",
              "    SELECTEDVALUE( 'Actuals-vs-PctChange'[Top-Bottom-Field] ) = \"MOM% Sales\",",
              "    SWITCH( ",
              "        TRUE(),",
              "        SELECTEDVALUE( DimEmployee[EmployeeKey] ) IN _Rank_Asc, \"#A30024\",",
              "        SELECTEDVALUE( DimEmployee[EmployeeKey] ) IN _Rank_Desc, \"#0D4FBD\",",
              "        \"black\"",
              "    ),",
              "    \"black\"",
              ")",
              "",
              "RETURN _Result"
            ],
            "lineageTag": "d0968c6b-3b06-43d4-9883-a68d8737b066"
          },
          {
            "name": "Rank",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "Table Dyamics",
