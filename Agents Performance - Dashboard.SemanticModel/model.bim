          {
            "name": "Number of Employees with Positive change PM",
            "displayFolder": "-KPI- Positive Change",
            "expression": [
              "",
              "IF (",
              "    [_ShowValueForDates],",
              "    CALCULATE (",
              "        [Employees with Positive Change %],",
              "        CALCULATETABLE (",
              "            DATEADD ( 'Date'[Date], -1, MONTH ),",
              "            'Date'[DateWithTransactions] = TRUE",
              "        )",
              "    )",
              ")"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "b4b4fa60-1a58-4ca3-801a-56c343e8252a"
          },
          {
            "name": "TopN/BottomN/ PMTD Sales",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "Dynamic Bar Charts",
            "expression": [
              "",
              "",
              "VAR _N = 'Top-Bottom-N'[Top-Bottom-N Value] ",
              "",
              "VAR _Avg_MTD_Asc =",
              "CALCULATE( ",
              "    [PMTD Total Sales],",
              "    FILTER( ALL(DimEmployee[EmployeeKey]), NOT ISBLANK([MTD Total Sales]) && NOT ISBLANK( DimEmployee[EmployeeKey] ) &&",
              "     [Rank MTD Asc] <= _N ) ",
              ")",
              "",
              "VAR _Avg_MTD_Desc =",
              "CALCULATE( ",
              "    [PMTD Total Sales],",
              "    FILTER( ALL(DimEmployee[EmployeeKey]), NOT ISBLANK([MTD Total Sales]) && NOT ISBLANK( DimEmployee[EmployeeKey] ) &&",
              "     [Rank MTD Desc] <= _N ) ",
              ")",
              "",
              "VAR _Avg_MTD_Others =",
              "CALCULATE( ",
              "    [PMTD Total Sales],",
              "    FILTER( ALL(DimEmployee[EmployeeKey]), NOT ISBLANK([MTD Total Sales]) && NOT ISBLANK( DimEmployee[EmployeeKey] ) &&",
              "     [Rank MTD Desc] > _N && [Rank MTD Desc] > _N ) ",
              ")",
              "",
              "RETURN ",
              "SWITCH( ",
              "    TRUE(),",
              "    SELECTEDVALUE( 'Clustered Employees'[Order] ) = 1, _Avg_MTD_Desc, ",
              "    SELECTEDVALUE( 'Clustered Employees'[Order] ) = 2, _Avg_MTD_Others, ",
              "    SELECTEDVALUE( 'Clustered Employees'[Order] ) = 3, _Avg_MTD_Asc",
              ")",
              "",
              ""
            ],
            "lineageTag": "9cf2bf0c-25cc-4700-b826-e96f9c8c44f2"
          },
          {
            "name": "dummy",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "[PMTD Total Sales]",
            "lineageTag": "eee3eb5c-71ed-4eda-93ea-ab160bd939f2"
          },
          {
            "name": "dummy (negative Bar)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "IF( [MTD Total Sales] <= [PMTD Total Sales], [MTD Total Sales] ) ",
            "lineageTag": "8fabe660-d4d2-4ae8-81e7-77f2eab39d7d"
          },
          {
            "name": "SVG 100% Stacked Bar Chart Employees Positive Change",
            "dataCategory": "ImageUrl",
            "displayFolder": "-KPI- Positive Change",
            "expression": [
              "",
              "",
              "VAR _goal = 0.55",
              "VAR _to_goal = DIVIDE( [Employees with Positive Change %], _goal ) ",
              "VAR _Adjusted_Width = _to_goal * 260",
              "",
              "VAR _Color_Lower_gradient = IF( _to_goal >= 0.8, \"#C6E3FF\", \"#F7C7D0\" )",
              "VAR _Color_Upper_gradient = IF( _to_goal >= 0.8, \"#118DFF\", \"#DC143C\" )",
              "",
              "",
              "VAR _Result = ",
              "\"data:image/svg+xml;utf8, <svg width='300' height='30' xmlns='http://www.w3.org/2000/svg'>",
              "  <!-- Define colors for the segments -->",
              "   <linearGradient id='grad1' x1='0%' y1='0%' x2='100%' y2='0%'>",
              "    <stop offset='0%' style='stop-color:\"&_Color_Lower_gradient&\";stop-opacity:1' />",
              "    <stop offset='\" & FORMAT(_to_goal, \"0%\") & \"' style='stop-color:\"&_Color_Upper_gradient&\";stop-opacity:1' />",
              "  </linearGradient>",
              "  ",
              "  <!-- Rounded rectangle background -->",
              "  <rect x='0' y='7.5' width='260' height='15' rx='7' ry='7' fill='#cccccc' />",
              "",
              "  <!-- Data -->",
              "  <rect x='0' y='7.5' width='\" & FORMAT(_Adjusted_Width, \"0\") & \"' height='15' rx='7' ry='7' fill='url(#grad1)' />",
              "",
              "  <!-- Vertical dashed line, at 80% -->",
              "  <line x1='\" & 260*0.8 &\"' y1='2.5' x2='\" & 260*0.8 &\"' y2='27.5' stroke='black' stroke-dasharray='5,5' />",
              "",
              "</svg>\"",
              "",
              "",
              "RETURN",
              "    _Result",
              ""
            ],
            "lineageTag": "c902e695-860d-4ff7-924b-f22d9ef12813"
          },
          {
            "name": "Target Employees Positive Change %",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "-KPI- Positive Change",
            "expression": "0.55",
            "lineageTag": "879161bf-ffbd-497a-a06c-7646702b16f2"
          },
          {
            "name": "KPI, Positive Change towards Target",
            "displayFolder": "-KPI- Positive Change",
            "expression": [
              "",
              "VAR _value = DIVIDE( [Employees with Positive Change %], 0.55 )",
              "VAR _indicator = IF( _value >= 0.8 , \"✔ \", \"✘ \")",
              "VAR _Result =",
              "REPT(\"‏‏‎ ‎\", 26) & _indicator & FORMAT( _value , \"0.0%\")",
              "",
              "RETURN  _Result"
            ],
            "lineageTag": "f3fac58a-d559-4b36-8c1d-9f50cb8083e7"
          },
          {
            "name": "Employees Positive Change vs Previous Month",
            "displayFolder": "-KPI- Positive Change",
            "expression": [
              "",
              "VAR _Value = ",
              "DIVIDE( ",
              "    [Employees with Positive Change %] - [Number of Employees with Positive change PM],",
              "    [Number of Employees with Positive change PM]",
              ")",
              "VAR _Indicator = ",
              "IF( _Value > 0 , \"▲\", \"▼\" )",
              "",
              "RETURN ",
              "REPT(\"‏‏‎ ‎\", 26) & ",
              "_Indicator &",
              "FORMAT( _Value, \"0.0%\") "
