          {
            "name": "Rank Filtering Employyees MTD%",
            "displayFolder": "Table Dyamics",
            "expression": [
              "",
              "",
              "VAR _Selected_Top_Bottom_N = 'Top-Bottom-N'[Top-Bottom-N Value]",
              "",
              "VAR _Rank_Asc =",
              "TOPN( ",
              "    _Selected_Top_Bottom_N ,",
              "    FILTER( ALL( DimEmployee[EmployeeKey] ),",
              "            NOT ISBLANK( [MTD Total Sales] ) ",
              "        ),",
              "    [MOMTD % Total Sales], ASC )",
              "",
              "VAR _Rank_Desc =",
              "TOPN( ",
              "    _Selected_Top_Bottom_N ,",
              "    FILTER( ALL( DimEmployee[EmployeeKey] ),",
              "            NOT ISBLANK( [MTD Total Sales] ) ",
              "        ),",
              "    [MOMTD % Total Sales], DESC )",
              "",
              "VAR _Rank_Middle_Empty_Bar =",
              "RANKX( FILTER( ALL( DimEmployee[EmployeeKey] ),NOT ISBLANK( [MTD Total Sales] )) , [MOMTD % Total Sales], , DESC ) ",
