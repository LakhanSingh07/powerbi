              "VAR _Rank_Middle_Empty_Bar =",
              "RANKX( FILTER( ALL( DimEmployee[EmployeeKey] ),NOT ISBLANK( [MTD Total Sales] )) , [MOMTD % Total Sales], , DESC ) ",
              "",
              "VAR _Rank_Middle_Empty_Bar_MTD =",
              "RANKX( FILTER( ALL( DimEmployee[EmployeeKey] ),NOT ISBLANK( [MTD Total Sales] )) , [MTD Total Sales], , DESC ) ",
              "",
              "",
              "VAR _Result =",
              "IF( ",
              "    SELECTEDVALUE( 'Actuals-vs-PctChange'[Top-Bottom-Field]) = \"MTD Sales\",",
              "    _Rank_Middle_Empty_Bar_MTD, _Rank_Middle_Empty_Bar",
