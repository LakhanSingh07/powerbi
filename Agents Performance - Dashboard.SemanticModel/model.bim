        "partitions": [
          {
            "name": "FactSales",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(\"F:\\Work\\# My-Freelance-World\\Dataset\\Cleaned Contoso Dataset\\FactSales.csv\"),[Delimiter=\",\", Columns=16, Encoding=1252, QuoteStyle=QuoteStyle.None]),",
                "    #\"Promoted Headers\" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(#\"Promoted Headers\",{{\"SalesKey\", Int64.Type}, {\"DateKey\", type date}, {\"channelKey\", Int64.Type}, {\"StoreKey\", Int64.Type}, {\"ProductKey\", Int64.Type}, {\"PromotionKey\", Int64.Type}, {\"CurrencyKey\", Int64.Type}, {\"UnitCost\", type number}, {\"UnitPrice\", type number}, {\"SalesQuantity\", Int64.Type}, {\"ReturnQuantity\", Int64.Type}, {\"ReturnAmount\", type number}, {\"DiscountQuantity\", Int64.Type}, {\"DiscountAmount\", type number}, {\"TotalCost\", type number}, {\"SalesAmount\", type number}}),",
                "    #\"Filtered Rows\" = Table.SelectRows(#\"Changed Type\", each [SalesKey] < 200000),",
                "    #\"Removed Columns\" = Table.RemoveColumns(#\"Filtered Rows\",{\"CurrencyKey\", \"PromotionKey\"})",
                "in",
                "    #\"Removed Columns\""
              ],
              "type": "m"
            }
          }
        ]
      },
      {
        "name": "# Measures",
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ],
        "lineageTag": "b6224613-9a70-4b57-b8b2-4cf4249bf2cf",
        "measures": [
          {
            "name": "Total Sales",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "SUM( FactSales[SalesAmount] ) ",
            "lineageTag": "0a76b18c-88d4-410a-8f0d-09883749d1aa"
          },
          {
            "name": "YTD Total Sales",
            "annotations": [
              {
                "name": "SQLBI_Template",
                "value": "TimeIntelligence"
              },
              {
                "name": "SQLBI_TimeIntelligence",
                "value": "Standard"
              },
              {
                "name": "SQLBI_CalendarType",
                "value": "Calendar"
              }
            ],
            "displayFolder": "Time intelligence\\To-date total\\Total Sales",
            "expression": [
              "",
              "IF (",
              "    [_ShowValueForDates],",
              "    CALCULATE (",
              "        [Total Sales],",
              "        DATESYTD ( 'Date'[Date] )",
              "    )",
              ")"
            ],
            "lineageTag": "a6af7fae-e590-486c-a67f-f7782ebece20"
          },
          {
            "name": "QTD Total Sales",
            "annotations": [
              {
                "name": "SQLBI_Template",
                "value": "TimeIntelligence"
              },
              {
                "name": "SQLBI_TimeIntelligence",
                "value": "Standard"
              },
              {
                "name": "SQLBI_CalendarType",
                "value": "Calendar"
              }
            ],
            "displayFolder": "Time intelligence\\To-date total\\Total Sales",
            "expression": [
              "",
              "IF (",
              "    [_ShowValueForDates],",
              "    CALCULATE (",
              "        [Total Sales],",
              "        DATESQTD ( 'Date'[Date] )",
              "    )",
              ")"
            ],
            "lineageTag": "66590c51-96e5-4b36-8a6c-a4ff1c385244"
          },
          {
            "name": "MTD Total Sales",
